[sub_resource type="Resource" id="Operation_grind"]
script = ExtResource("3_operation")
Id = &"grind_coffee"
DisplayName = "研磨"
RequiredPlacementToolIds = Array[StringName]([&"mortar"])
RequiredHandheldToolId = &"pestle"
InputIngredientIds = Array[StringName]([&"coffee_beans"])
InputTargetAmounts = Array[float]([1.0])
OutputIngredientIds = Array[StringName]([&"ground_coffee"])
OutputAmounts = Array[float]([1.0])
ResultTargetToolId = &"mortar"
RequiredAction = 0.6

[sub_resource type="Resource" id="Operation_extract"]
script = ExtResource("3_operation")
Id = &"manual_extract"
DisplayName = "浸润萃取"
RequiredPlacementToolIds = Array[StringName]([&"traditional_filter"])
AllowedHandheldToolIds = Array[StringName]([&"jigger_small", &"jigger_medium", &"jigger_large"])
InputIngredientIds = Array[StringName]([&"ground_coffee", &"water"])
InputTargetAmounts = Array[float]([1.0, 30.0])
OutputIngredientIds = Array[StringName]([&"coffee_extract"])
OutputAmounts = Array[float]([30.0])
ResultTargetToolId = &"traditional_filter"
RepeatRecoveryInputIngredientId = &"coffee_extract"
RepeatRecoveryCap = 0.96
RepeatRecoveryFraction = 0.42
RequiredAction = 0.7

[sub_resource type="Resource" id="Operation_filter"]
