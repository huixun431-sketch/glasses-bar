[resource]
script = ExtResource("1_catalog")
Tools = Array[ExtResource("2_tool")]([SubResource("Tool_glass"), SubResource("Tool_mortar"), SubResource("Tool_filter"), SubResource("Tool_pestle"), SubResource("Tool_scoop"), SubResource("Tool_tongs"), SubResource("Tool_jigger_small"), SubResource("Tool_jigger_medium"), SubResource("Tool_jigger_large")])
