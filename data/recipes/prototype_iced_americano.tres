[gd_resource type="Resource" script_class="RecipeDefinition" load_steps=13 format=3]

[ext_resource type="Script" path="res://scripts/data/RecipeDefinition.cs" id="1_recipe"]
[ext_resource type="Script" path="res://scripts/data/RecipeStep.cs" id="2_step"]
[ext_resource type="Script" path="res://scripts/data/ToleranceProfile.cs" id="3_tolerance"]

[sub_resource type="Resource" id="Step_glass"]
script = ExtResource("2_step")
Id = &"take_glass"
DisplayName = "拿取高球杯"

[sub_resource type="Resource" id="Step_ice"]
script = ExtResource("2_step")
Id = &"add_ice"
DisplayName = "加入冰"
IngredientId = &"ice"

[sub_resource type="Resource" id="Step_water"]
script = ExtResource("2_step")
Id = &"add_water"
DisplayName = "手工倒水"
IngredientId = &"water"

[sub_resource type="Resource" id="Step_grind"]
script = ExtResource("2_step")
Id = &"grind_coffee"
DisplayName = "研磨咖啡豆"

[sub_resource type="Resource" id="Step_mortar"]
script = ExtResource("2_step")
Id = &"take_mortar"
DisplayName = "拿取研钵与研杵"

[sub_resource type="Resource" id="Step_beans"]
script = ExtResource("2_step")
Id = &"take_coffee_beans"
DisplayName = "从后吧台取用咖啡豆"

[sub_resource type="Resource" id="Step_filter_tool"]
script = ExtResource("2_step")
Id = &"take_filter"
DisplayName = "拿取传统滤具"

[sub_resource type="Resource" id="Step_extract"]
script = ExtResource("2_step")
Id = &"manual_extract"
DisplayName = "手工浸润萃取"

[sub_resource type="Resource" id="Step_filter"]
script = ExtResource("2_step")
Id = &"filter_coffee"
DisplayName = "过滤咖啡液入杯"
IngredientId = &"espresso"

[sub_resource type="Resource" id="Tolerance_prototype"]
script = ExtResource("3_tolerance")
AmountToleranceRatio = 0.1
EnableQuantityScoring = false

[resource]
script = ExtResource("1_recipe")
Id = &"prototype_iced_americano"
DisplayName = "冰美式（开发占位）"
IsPrototype = true
Steps = Array[ExtResource("2_step")]([SubResource("Step_glass"), SubResource("Step_ice"), SubResource("Step_water"), SubResource("Step_mortar"), SubResource("Step_beans"), SubResource("Step_grind"), SubResource("Step_filter_tool"), SubResource("Step_extract"), SubResource("Step_filter")])
Tolerance = SubResource("Tolerance_prototype")
